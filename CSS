body { 
    background: gray; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
    height: 100vh; 
    margin: 0; 
}
.form-container { 
    background: blue; 
    padding: 30px; 
    border-radius: 10px; 
    width: 300px; 
}
h2 { text-align: center; }
label { display: block; margin-top: 5px; font-weight: bold; }
input, select { width: 100%; padding: 8px; margin-top: 5px; box-sizing: border-box; }
button { width: 100%; padding: 10px; background: #0056b3; color: white; border: none; margin-top: 15px; cursor: pointer; border-radius: 4px; }
